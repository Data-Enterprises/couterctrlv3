{
  "name": "counterctrlv3",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui --api 9527",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -b && vite build",
    "deploy": "npm run build && aws s3 sync dist s3://www.counterctrlcloud.com --delete --cache-control \"public, max-age=31536000, immutable\" && aws s3 cp dist/index.html s3://www.counterctrlcloud.com/index.html --cache-control \"no-cache, no-store, must-revalidate\" && aws cloudfront create-invalidation --distribution-id EGRZX5CPCZSSN --paths=\"/*\"",
    "publish": "npm run deploy",
    "build:test": "vite build"
  },
  "dependencies": {
    "@ericblade/quagga2": "^1.8.4",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/heatmap": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@reduxjs/toolkit": "^2.10.1",
    "@tailwindcss/forms": "^0.5.9",
    "ag-grid-community": "^34.3.1",
    "ag-grid-react": "^34.3.1",
    "axios": "^1.13.2",
    "react": "^19.1.1",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-media-devices": "^1.2.1",
    "react-redux": "^9.2.0",
    "react-router": "^7.9.5",
    "tailwind-rounded-out": "^1.0.1",
    "tw-elements": "^2.0.0",
    "vite-plugin-istanbul": "^7.2.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/zxcvbn": "^4.4.5",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.7",
    "@vitest/ui": "^4.0.7",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.14",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^27.1.0",
    "ndarray-pixels": "^5.0.1",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vitest": "^4.0.7"
  },
  "vitest": {
    "maxWorkers": 5
  }
}
